# StayManager Hotel Chatbot Environment Variables
# Copy this file to .env.local and fill in your actual values

# ===========================================
# AI & n8n Configuration
# ===========================================

# === FREE AI API OPTIONS (RECOMMENDED) ===

# Groq API Key (RECOMMENDED - Fast & Free)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini API Key (Alternative Free Option)
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace API Token (Completely Free)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here

# === PAID AI API OPTIONS ===

# OpenAI API Key (Paid)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude API Key (Paid)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-claude-key-here

# n8n Webhook URL (where n8n is running)
# Local development: http://localhost:5678/webhook/hotel-chatbot
# Production: https://your-n8n-domain.com/webhook/hotel-chatbot  
N8N_WEBHOOK_URL=http://localhost:5678/webhook/hotel-chatbot

# ===========================================
# Next.js Configuration
# ===========================================

# Public API URL for chatbot (accessible from browser)
# Local: http://localhost:3000/api/chatbot
# Production: https://your-domain.com/api/chatbot
NEXT_PUBLIC_CHATBOT_API_URL=http://localhost:3000/api/chatbot

# ===========================================
# Hotel Information (used by AI)
# ===========================================

# Basic hotel information for AI context
HOTEL_NAME="StayManager Hotel"
HOTEL_LOCATION="Jakarta, Indonesia"
HOTEL_PHONE="+62-21-1234-5678"
HOTEL_EMAIL="info@staymanager.com"
HOTEL_WEBSITE="https://staymanager.com"

# Check-in/out times
CHECKIN_TIME="14:00"
CHECKOUT_TIME="12:00"

# Hotel facilities (comma separated)
HOTEL_FACILITIES="Pool,Restaurant,Spa,Gym,Business Center,WiFi,Parking,Room Service"

# ===========================================
# Security & Authentication (Optional)
# ===========================================

# API Authentication token for hotel endpoints (if needed)
# HOTEL_API_TOKEN=your-internal-api-token

# n8n Basic Auth (for n8n dashboard access)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-password

# ===========================================
# Database Configuration
# ===========================================
# These should already be configured for StayManager
# Uncomment and modify if needed for chatbot database access

# SUPABASE_URL=your-supabase-url
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================================
# Development Settings
# ===========================================

# Enable debug mode
NODE_ENV=development

# Next.js port (default: 3000)
PORT=3000

# n8n settings
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http

# ===========================================
# Production Settings (uncomment for production)
# ===========================================

# NODE_ENV=production
# N8N_PROTOCOL=https
# N8N_HOST=your-n8n-domain.com
# WEBHOOK_URL=https://your-n8n-domain.com