flowchart TD
    Start([Mulai]) --> Akses[User akses /login]
    Akses --> Form[Tampilkan form email + password]
    Form --> Input[User input kredensial]
    Input --> Submit[Klik tombol Sign In]
    Submit --> ValidClient{Validasi client<br/>field tidak kosong?}
    ValidClient -->|Tidak| ErrField[Tampilkan error<br/>'Field wajib diisi']
    ErrField --> Form
    ValidClient -->|Ya| AuthCall[supabase.auth.<br/>signInWithPassword]
    AuthCall --> AuthResp{Response Supabase}
    AuthResp -->|400 invalid_grant| ErrCred[Toast 'Failed to login']
    ErrCred --> Form
    AuthResp -->|200 user + session| FetchRoles[Query user_roles<br/>JOIN roles]
    FetchRoles --> RolesEmpty{userRoles<br/>empty?}
    RolesEmpty -->|Ya| Default[Anggap role 'guest'<br/>permissions = chatbot only]
    RolesEmpty -->|Tidak| MapRoles[Map roles ke array]
    MapRoles --> CheckGuest{hasGuestRole<br/>AND length == 1?}
    Default --> RedirChat[window.location.href<br/>= '/chatbot']
    CheckGuest -->|Ya| RedirChat
    CheckGuest -->|Tidak| RedirDash[window.location.href<br/>= '/dashboard']
    RedirChat --> MWGuest[Middleware verify JWT]
    RedirDash --> MWStaff[Middleware verify JWT]
    MWGuest --> RenderChat[Render /chatbot]
    MWStaff --> RenderDash[Render /dashboard sesuai role]
    RenderChat --> End([Selesai])
    RenderDash --> End

    classDef startEnd fill:#dcfce7,stroke:#10b981,stroke-width:2px
    classDef decision fill:#fef3c7,stroke:#f59e0b
    classDef action fill:#dbeafe,stroke:#3b82f6
    classDef error fill:#fee2e2,stroke:#ef4444

    class Start,End startEnd
    class ValidClient,AuthResp,RolesEmpty,CheckGuest decision
    class Akses,Form,Input,Submit,AuthCall,FetchRoles,MapRoles,Default,RedirChat,RedirDash,MWGuest,MWStaff,RenderChat,RenderDash action
    class ErrField,ErrCred error
