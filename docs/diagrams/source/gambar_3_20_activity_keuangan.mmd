flowchart TD
    Start([Staff Finance login]) --> Hub{Pilih modul keuangan}

    Hub -->|Pendapatan / Income| FinPage["/financial - dashboard KPI"]
    Hub -->|Pengeluaran| ExpPage["/expenses page"]
    Hub -->|Billing & Invoice| BillPage["/billing page"]

    FinPage --> FinKPI[Tampilkan KPI:<br/>total revenue MTD,<br/>total expenses,<br/>net profit, pending tx]
    FinKPI --> FinFilter[Filter periode<br/>day week month custom]
    FinFilter --> FinList[List transaksi<br/>JOIN reservations + payments]

    ExpPage --> ExpList[List expenses<br/>filter category period]
    ExpList --> ExpAct{Aksi?}
    ExpAct -->|Add expense| ExpForm[Form: tanggal, kategori,<br/>amount, vendor, payment_method,<br/>description]
    ExpForm --> ExpValid{amount > 0?}
    ExpValid -->|Tidak| ExpErr[Error 'Jumlah harus > 0']
    ExpErr --> ExpForm
    ExpValid -->|Ya| ExpInsert[(INSERT expenses<br/>status='pending'<br/>or 'approved')]
    ExpInsert --> RecalcKPI[Recalculate KPI<br/>refresh dashboard]

    BillPage --> BillList[List invoices + billing_items]
    BillList --> BillAct{Aksi?}
    BillAct -->|Add Invoice| InvForm[Form: reservation_id,<br/>tax_amount, service_charge,<br/>discount]
    InvForm --> InvCalc[Hitung total_amount =<br/>subtotal + tax + service - discount]
    InvCalc --> InvInsert[(INSERT invoices<br/>generate invoice_number)]

    BillAct -->|Add Billing Item| ItemForm[Form: reservation,<br/>item_name, category,<br/>quantity, unit_price]
    ItemForm --> ItemCalc[total_price =<br/>quantity x unit_price]
    ItemCalc --> ItemInsert[(INSERT billing_items<br/>status='pending')]

    BillAct -->|Mark Paid| MarkPaid[(UPDATE billing_items<br/>SET status='paid'<br/>WHERE id IN selected)]
    MarkPaid --> InsertPay[(INSERT payments<br/>amount + method + txId)]

    InvInsert --> RecalcKPI
    ItemInsert --> RecalcKPI
    InsertPay --> RecalcKPI

    RecalcKPI --> Reports{Generate<br/>laporan?}
    Reports -->|Ya| ReportPage["/reports - filter periode"]
    ReportPage --> ReportData[Aggregate via<br/>/api/reports/analytics]
    ReportData --> ReportRender[Render chart + tabel]
    ReportRender --> ExportOpt{Export?}
    ExportOpt -->|Ya| Export[Trigger /api/reports/export<br/>or window.print]
    ExportOpt -->|Tidak| End
    Export --> End([Selesai])

    Reports -->|Tidak| End

    classDef startEnd fill:#dcfce7,stroke:#10b981
    classDef decision fill:#fef3c7,stroke:#f59e0b
    classDef action fill:#dbeafe,stroke:#3b82f6
    classDef db fill:#e0e7ff,stroke:#6366f1
    classDef error fill:#fee2e2,stroke:#ef4444

    class Start,End startEnd
    class Hub,ExpAct,ExpValid,BillAct,Reports,ExportOpt decision
    class FinPage,FinKPI,FinFilter,FinList,ExpPage,ExpList,ExpForm,BillPage,BillList,InvForm,InvCalc,ItemForm,ItemCalc,RecalcKPI,ReportPage,ReportData,ReportRender,Export action
    class ExpInsert,InvInsert,ItemInsert,MarkPaid,InsertPay db
    class ExpErr error
