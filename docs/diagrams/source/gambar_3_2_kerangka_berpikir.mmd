    classDef impl fill:#e0e7ff,stroke:#6366f1
    classDef eval fill:#fce7f3,stroke:#ec4899

    class Start,End startEnd
    class Problem,Lit,Compare,Gap,Need phase
    class Design,Stack analysis
    class Implement,Modules impl
