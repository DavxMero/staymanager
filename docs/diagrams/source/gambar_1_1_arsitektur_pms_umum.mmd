flowchart LR
    subgraph FrontOffice["Front Office Layer"]
        FD[Reception<br/>Front Desk]
        Res[Reservation<br/>Module]
        Concierge[Guest Services<br/>Concierge]
    end

    subgraph CorePMS["Core PMS Engine"]
        RoomMgmt[Room Inventory<br/>& Status]
        GuestProf[Guest Profile<br/>& History]
        Folio[Guest Folio<br/>Charges]
        Rates[Rate Management<br/>& Yield]
    end

    subgraph BackOffice["Back Office Layer"]
        HK[Housekeeping<br/>Coordination]
        Maint[Maintenance<br/>Scheduling]
        Acct[Accounting<br/>& Billing]
        Invent[Inventory<br/>Management]
        Reports[Reporting &<br/>Business Intelligence]
    end

    subgraph Distribution["Distribution Layer"]
        OTA[OTA Connectors<br/>Booking.com Agoda]
        DirectWeb[Direct Booking<br/>Engine]
        ChannelMgr[Channel<br/>Manager]
    end

    subgraph DataLayer["Data Layer"]
        DB[(Centralized<br/>Database)]
    end

    subgraph External["External Integrations"]
        PG[Payment<br/>Gateway]
        POS[Point of Sale<br/>Restaurant Bar]
        CRM[CRM &<br/>Loyalty Program]
    end

    FD --> Res
    Res --> RoomMgmt
    Res --> GuestProf
    Concierge --> GuestProf
    FD --> Folio

    RoomMgmt --> HK
    RoomMgmt --> Maint
    Folio --> Acct
    HK --> RoomMgmt

    Acct --> Invent
    Acct --> Reports
    GuestProf --> Reports
    RoomMgmt --> Reports
    Rates --> Reports

    DirectWeb --> Res
    OTA --> ChannelMgr
    ChannelMgr --> Res
    Rates --> ChannelMgr

    Folio --> PG
    POS --> Folio
    GuestProf --> CRM

    FrontOffice --> DB
    CorePMS --> DB
    BackOffice --> DB
    Distribution --> DB

    classDef front fill:#fef3c7,stroke:#f59e0b
    classDef core fill:#dbeafe,stroke:#3b82f6
    classDef back fill:#dcfce7,stroke:#10b981
