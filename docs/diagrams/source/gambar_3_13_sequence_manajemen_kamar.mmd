sequenceDiagram
    autonumber
    actor Staff as Manager / Super Admin
    participant UI as Rooms Page<br/>(/rooms/page.tsx Tab Rooms)
    participant API as /api/rooms/route.ts
    participant SB as Supabase Client
    participant DB as PostgreSQL

    Staff->>UI: Buka /rooms (default tab Rooms)
    UI->>API: GET /api/rooms
    API->>SB: from('rooms').select('*, custom_room_types(*)')
    SB->>DB: SELECT rooms LEFT JOIN custom_room_types
    DB-->>SB: rooms[]
    SB-->>API: rooms data
    API-->>UI: 200 OK
    UI-->>Staff: Render tabel kamar + filter

    rect rgb(220, 252, 231)
    Note over Staff,DB: CREATE Room
    Staff->>UI: Klik "Add Room" buka dialog
    Staff->>UI: Isi: number, type, floor,<br/>base_price, custom_type_id
    UI->>API: POST /api/rooms { roomData }
    API->>API: Validate body (Zod)
    API->>SB: from('rooms').insert(roomData)
    SB->>DB: INSERT INTO rooms
    alt Number duplicate
        DB-->>SB: 23505 unique violation
        SB-->>API: error
        API-->>UI: 400 Bad Request
        UI-->>Staff: Toast "Nomor kamar sudah ada"
    else Success
        DB-->>SB: new room row
        SB-->>API: data
        API-->>UI: 201 Created
        UI->>UI: Refresh list
        UI-->>Staff: Toast "Kamar ditambahkan"
    end
    end

    rect rgb(219, 234, 254)
    Note over Staff,DB: UPDATE Room
    Staff->>UI: Klik edit pada baris kamar
    Staff->>UI: Ubah field (mis. base_price)
    UI->>API: PUT /api/rooms/{id}
    API->>SB: from('rooms').update(...).eq('id', id)
    SB->>DB: UPDATE rooms
    DB-->>SB: updated row
    SB-->>API: data
    API-->>UI: 200 OK
    UI-->>Staff: Toast "Kamar diperbarui"
    end

    rect rgb(254, 226, 226)
    Note over Staff,DB: DELETE Room
    Staff->>UI: Klik delete pada baris kamar
    UI->>UI: Buka confirm dialog
    Staff->>UI: Konfirmasi delete
    UI->>API: DELETE /api/rooms/{id}
    API->>SB: from('rooms').delete().eq('id', id)
    SB->>DB: DELETE FROM rooms
    DB-->>SB: deleted count
    SB-->>API: ok
    API-->>UI: 204 No Content
    UI->>UI: Refresh list
    UI-->>Staff: Toast "Kamar dihapus"
    end

    rect rgb(254, 243, 199)
    Note over Staff,DB: UPDATE Status Kamar Quick Action
    Staff->>UI: Pilih status baru di dropdown<br/>(available / cleaning / maintenance)
    UI->>SB: from('rooms').update({status}).eq('id', id)
    SB->>DB: UPDATE rooms SET status=?
    DB-->>SB: ok
    Note over DB: Realtime channel emit:<br/>dashboard subscribers update<br/>occupancy subscribers update
    end
