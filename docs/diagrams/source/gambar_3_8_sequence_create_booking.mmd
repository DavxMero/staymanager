sequenceDiagram
    autonumber
    actor Tamu as Tamu Hotel
    participant ChatUI as Chatbot UI<br/>(/chatbot/page.tsx)
    participant ChatAPI as Chat Route<br/>(/api/chat/route.ts)
    participant Gemini as Google Gemini<br/>(gemini-2.5-flash)
    participant Tool as Tool: createBooking
    participant DB as Supabase PostgreSQL

    Tamu->>ChatUI: Pilih kamar dari ROOM_CARDS<br/>+ konfirmasi data tamu
    ChatUI->>ChatAPI: POST /api/chat<br/>{messages: [..., booking confirmation]}

    ChatAPI->>Gemini: streamText({tools: {createBooking, ...}})

    Gemini->>Gemini: Validate guest info complete<br/>(name, email, phone, dates, roomId)

    Gemini->>Tool: invoke createBooking({<br/>guestName, guestEmail, guestPhone,<br/>roomId, roomNumber, roomType,<br/>checkIn, checkOut, adults, children,<br/>roomRate, breakfastIncluded<br/>})

    Tool->>Tool: bookingRef = "BK" + Date.now().slice(-8)<br/>bookingId = "BOOK-" + Date.now()<br/>nights = (checkOut - checkIn) / 86400000<br/>roomTotal = roomRate × nights<br/>breakfastTotal = pax × 50000 × nights<br/>totalAmount = roomTotal + breakfastTotal

    Tool->>DB: SELECT id FROM guests WHERE email = ?
    DB-->>Tool: existingGuest (atau null)

    alt Guest belum ada
        Tool->>DB: INSERT INTO guests<br/>(full_name, email, phone)
        DB-->>Tool: newGuest.id
        Tool->>Tool: guestId = newGuest.id
    else Guest sudah terdaftar
        Tool->>Tool: guestId = existingGuest.id
    end

    Tool->>DB: INSERT INTO reservations (<br/>booking_id, booking_reference,<br/>guest_id, room_id, room_number, room_type,<br/>check_in, check_out, adults, children,<br/>guest_count, room_rate, room_total,<br/>breakfast_included, breakfast_total,<br/>total_amount, total_price,<br/>status='confirmed',<br/>payment_status='pending'<br/>)
    DB-->>Tool: reservation row

    Tool-->>Gemini: { success: true,<br/>bookingReference,<br/>reservationId,<br/>totalAmount,<br/>status: 'confirmed',<br/>paymentStatus: 'pending',<br/>message: 'Awaiting payment...' }

    Gemini->>Gemini: Generate response<br/>+ append SHOW_PAYMENT_OPTIONS_JSON

    Gemini-->>ChatAPI: stream chunks (SSE)
    ChatAPI-->>ChatUI: stream response

    ChatUI->>ChatUI: Render <PaymentOptions /><br/>(Bank Transfer / Credit / E-Wallet)

    ChatUI-->>Tamu: Tampilkan ringkasan booking<br/>+ opsi pembayaran<br/>(booking code TIDAK ditampilkan)

    Note over Tool: Booking code di-hold<br/>sampai pembayaran dikonfirmasi<br/>(business rule di system prompt)
