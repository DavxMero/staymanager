  "api_chat": {
    "file": "src/app/api/chat/route.ts",
    "llm_provider": "Google Gemini via @ai-sdk/google + Vercel AI SDK (streamText)",
    "model_default": "gemini-2.5-flash",
    "model_alternatif": "gemini-2.5-pro",
    "env_key": "GOOGLE_GENERATIVE_AI_API_KEY",
    "config_runtime": { "maxRetries": 2, "toolChoice": "auto", "maxSteps": 3, "maxDuration": 60 },
    "tools": [
      {
        "nama": "cekKetersediaan",
        "deskripsi": "Cek ketersediaan kamar real-time untuk rentang tanggal",
        "parameter": { "checkIn": "string (wajib)", "checkOut": "string (wajib)", "tipeKamar": "string (opsional)" },
        "logika_kunci": "Cari reservasi overlap (status BUKAN cancelled/no_show/checked-out/checked_out, check_in<checkOut, check_out>checkIn); kecualikan room busy + status maintenance/out_of_order; enrich dari custom_room_types."
      },
      {
        "nama": "createBooking",
        "deskripsi": "Buat reservasi baru setelah semua data tamu terkumpul",
        "parameter": {
          "guestName": "string (wajib)", "guestEmail": "email (wajib)", "guestPhone": "string (wajib)",
          "roomId": "uuid (wajib)", "roomNumber": "string (wajib)", "roomType": "string (wajib)",
          "checkIn": "string (wajib)", "checkOut": "string (wajib)",
          "adults": "number (default 1)", "children": "number (default 0)", "roomRate": "number (wajib)",
          "notes": "string (opsional)", "breakfastIncluded": "boolean (default false)"
        },
        "auth": "Wajib verifiedUser (login); jika tidak -> AUTH_REQUIRED",
        "insert": "reservations status='confirmed', payment_status='pending'; breakfast 50000/pax/malam"
      },
      {
        "nama": "confirmPayment",
        "deskripsi": "Konfirmasi pembayaran berdasarkan booking reference",
        "parameter": { "bookingReference": "string (wajib)", "paymentMethod": "string (opsional)", "paymentAmount": "number (opsional)" },
        "auth": "Wajib verifiedUser",
        "ownership_check": "Bandingkan reservation.guest_email vs verifiedUser.email (lowercase, case-insensitive). Mismatch -> tolak 'Anda tidak memiliki akses'.",
        "efek": "INSERT payments + UPDATE reservations.payment_status='paid'; baru ungkap booking_reference ke tamu."
      },
      {
        "nama": "getRoomTypes",
        "deskripsi": "Daftar tipe kamar + harga mulai",
        "parameter": {}
      }
    ]
  },

  "booking_code_generator": {
    "tabel": "reservations",
    "kolom": {
      "booking_id": { "unique": true, "pola": "BK + Date.now().slice(-8) + suffix4", "contoh": "BK12345678ABCD" },
      "booking_reference": { "unique": true, "pola": "BK + Date.now().slice(-6) + suffix6", "contoh": "BK872690QLGBYC", "dipakai_untuk": "konfirmasi pembayaran & ditampilkan ke tamu" }
    },
    "suffix": "Math.random().toString(36).slice(2,8).toUpperCase()",
    "guest_email_column_exists": true
  },

  "db_constraints": {
    "source": "introspeksi pg_constraint live",
    "no_overlap_active_reservations": {
      "tipe": "EXCLUDE (GiST)",
      "definisi": "EXCLUDE USING gist (room_id WITH =, daterange(check_in, check_out, '[)') WITH &&) WHERE status = ANY (ARRAY['confirmed','checked-in']) AND room_id IS NOT NULL",
      "arti": "Database MENJAMIN tidak ada dua reservasi confirmed/checked-in dengan kamar sama yang tanggalnya tumpang tindih (anti double-booking)."
    },
    "check_lain": ["check_in < check_out", "adults >= 0", "children >= 0", "enum status", "enum payment_status"],
    "reservations_status_enum": ["pending", "confirmed", "checked-in", "checked-out", "cancelled", "no_show"],
    "reservations_payment_status_enum": ["pending", "partial", "paid", "refunded"],
    "rooms_type_fk": {
      "formal": true,
      "definisi": "FOREIGN KEY (type) REFERENCES custom_room_types(name) ON UPDATE CASCADE"
    },
    "roles_columns": ["id uuid PK", "name text", "display_name text", "description text", "permissions jsonb", "created_at timestamptz", "updated_at timestamptz"],
    "rooms_columns": ["id uuid PK", "number varchar", "type varchar (FK->custom_room_types.name)", "floor integer", "base_price numeric", "status varchar", "created_at timestamptz", "updated_at timestamptz", "image_url text", "images jsonb"]
  },

  "rbac_roles": {
    "source": "tabel public.roles (live, 6 baris)",
    "roles": [
      { "name": "super_admin", "display_name": "Super Admin", "permissions": ["*"] },
      { "name": "manager", "display_name": "Manager", "permissions": ["dashboard", "reports", "guests", "rooms", "occupancy", "billing", "staff", "settings"] },
      { "name": "finance", "display_name": "Finance", "permissions": ["billing", "financial", "reports"] },
