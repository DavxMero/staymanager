      { "name": "housekeeping", "display_name": "Housekeeping", "permissions": ["rooms", "occupancy"] },
      { "name": "guest", "display_name": "Guest", "permissions": ["chatbot", "my_bookings"] }
    ],
    "catatan_penting": "BERBEDA dari profiles.role (CHECK enum: admin, manager, front-desk, housekeeping, maintenance, chef, waiter, cashier) yang merupakan jabatan staf/departemen, BUKAN RBAC.",
    "route_permission_map": {
      "/dashboard": "dashboard", "/rooms": "rooms", "/occupancy": "occupancy", "/guests": "guests",
      "/staff": "staff", "/financial": "billing", "/billing": "billing", "/logistics": "operations",
      "/reports": "reports", "/roles": "settings", "/expenses": "billing"
    },
    "guest_allowed_routes": ["/chatbot", "/settings", "/dashboard"],
    "public_routes": ["/login", "/signup", "/auth/callback", "/chatbot"]
  },

  "app_routes": {
