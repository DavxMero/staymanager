---
title: Contoh Class Diagram
---
classDiagram
    class Account {
        +String accountNumber
        -Double balance
        #Date openedAt
        +deposit(amount) void
        +withdraw(amount) Boolean
        +getBalance() Double
    }
    class SavingsAccount {
        -Double interestRate
        +calculateInterest() Double
    }
    class CurrentAccount {
        -Double overdraftLimit
        +checkOverdraft() Boolean
    }
    class Customer {
        +String customerId
        +String fullName
        -String address
        +String phone
        +viewAccounts() List
    }
    Account <|-- SavingsAccount : pewarisan
    Account <|-- CurrentAccount : pewarisan
    Customer "1" o-- "0..*" Account : agregasi (memiliki)
