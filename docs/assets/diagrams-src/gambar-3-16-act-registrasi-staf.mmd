---
title: Activity Diagram - Registrasi Akun Staf
---
flowchart TD
    Start([Mulai]) --> AdminLogin[Admin Login]
    AdminLogin --> NavStaff[Buka /staff]
    NavStaff --> ClickAdd[Klik 'Tambah Staf']
    ClickAdd --> InputData[Input Email, Nama, Posisi]
    InputData --> SelectRole[Pilih Role<br/>front_desk / housekeeping / finance / manager]
    SelectRole --> Submit[Klik Simpan]
    Submit --> ValidEmail{Email Sudah<br/>Terdaftar?}
    ValidEmail -->|Ya| ErrDup[Tampilkan 'Email duplikat']
    ErrDup --> InputData
    ValidEmail -->|Tidak| CreateAuth[Supabase admin.createUser]
    CreateAuth --> InsertProfile[INSERT INTO profiles]
    InsertProfile --> InsertUserRole[INSERT INTO user_roles]
    InsertUserRole --> SendEmail[Kirim Email Invitation]
    SendEmail --> Notif[Tampilkan Toast Sukses]
    Notif --> End([Selesai])

    classDef startEnd fill:#c8e6c9,stroke:#2e7d32,color:#000
    classDef decision fill:#fff9c4,stroke:#f57f17,color:#000
    classDef action fill:#bbdefb,stroke:#1565c0,color:#000
    classDef error fill:#ffcdd2,stroke:#c62828,color:#000
    class Start,End startEnd
    class ValidEmail decision
    class AdminLogin,NavStaff,ClickAdd,InputData,SelectRole,Submit,CreateAuth,InsertProfile,InsertUserRole,SendEmail,Notif action
    class ErrDup error
