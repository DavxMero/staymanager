---
title: Contoh Activity Diagram
---
flowchart TD
    Start((●)) --> A1[Masukkan Kartu ATM]
    A1 --> A2[Input PIN]
    A2 --> D1{PIN Valid?}
    D1 -->|Tidak| A3[Tampilkan Pesan Error]
    A3 --> D2{Sudah 3x<br/>Salah?}
    D2 -->|Tidak| A2
    D2 -->|Ya| A4[Blokir Kartu]
    A4 --> EndErr(((●)))
    D1 -->|Ya| A5[Tampilkan Menu Utama]
    A5 --> A6[Pilih Tarik Tunai]
    A6 --> A7[Input Nominal]
    A7 --> D3{Saldo<br/>Mencukupi?}
    D3 -->|Tidak| A8[Tampilkan 'Saldo Tidak Cukup']
    A8 --> EndErr
    D3 -->|Ya| Fork[/Eksekusi Paralel/]
    Fork --> A9[Debit Saldo]
    Fork --> A10[Keluarkan Uang Tunai]
    A9 --> Join[/Sinkronisasi/]
    A10 --> Join
    Join --> A11[Cetak Struk]
    A11 --> End(((●)))

    classDef startNode fill:#000,stroke:#000,color:#fff
    classDef endNode fill:#fff,stroke:#000,stroke-width:3px,color:#000
    classDef action fill:#bbdefb,stroke:#1565c0,stroke-width:1px,color:#000
    classDef decision fill:#fff9c4,stroke:#f57f17,stroke-width:1px,color:#000
    classDef bar fill:#000,stroke:#000,color:#fff
    class Start startNode
    class End,EndErr endNode
    class A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11 action
    class D1,D2,D3 decision
    class Fork,Join bar
