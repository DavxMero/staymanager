# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url_here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# Google Gemini API (used by @ai-sdk/google for the chatbot)
# Get from: https://ai.google.dev/
# Multi-key: pisahkan dengan koma untuk round-robin (2 key = 40 req/min effective)
# Contoh: GOOGLE_GENERATIVE_AI_API_KEY="AIzaSyXX...,AIzaSyYY..."
GOOGLE_GENERATIVE_AI_API_KEY="your_google_generative_ai_api_key_here"

# Groq API (opsional — model Llama gratis, 30 req/menit, super cepat)
# Get from: https://console.groq.com/keys
# Free tier: Llama 3.3 70B (30 RPM, 1000 RPD) + Llama 3.1 8B Instant (30 RPM, 14400 RPD)
# Multi-key: sama seperti Gemini, pisahkan dengan koma untuk round-robin
GROQ_API_KEY="your_groq_api_key_here"
