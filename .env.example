# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url_here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# Google Gemini API (used by @ai-sdk/google for the chatbot)
# Get from: https://ai.google.dev/apikey
# Models supported: Gemini 2.5 Flash (default), 2.5 Pro, 2.0 Flash, 2.0 Flash Lite
# Multi-key: pisahkan dengan koma untuk round-robin load distribution
# Contoh: GOOGLE_GENERATIVE_AI_API_KEY="AIzaSyXX...,AIzaSyYY..."
GOOGLE_GENERATIVE_AI_API_KEY="your_google_generative_ai_api_key_here"
