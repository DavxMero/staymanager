# Konfigurasi Playwright untuk capture screenshot Bab 4
# Copy file ini menjadi .env lalu isi nilainya

# URL deployment StayManager (default: production Vercel)
BASE_URL=https://staymanager.vercel.app

# Demo akun staff (super_admin atau manager) — akses ke semua modul
DEMO_EMAIL=
DEMO_PASSWORD=

# Demo akun guest — untuk capture chatbot mode login
DEMO_GUEST_EMAIL=
DEMO_GUEST_PASS=

# Demo akun super_admin — untuk capture modul Inventaris/Logistik (operations permission)
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASS=
