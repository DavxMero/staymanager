flowchart TB
    subgraph Page["Halaman Manajemen Kamar"]
        direction TB

        subgraph TopBar["Top Bar (sticky)"]
            direction LR
            SBToggle[Sidebar Toggle]
            Breadcrumb[Breadcrumb<br/>Dashboard > Kamar]
            Search[Global Search]
            UserMenu[Avatar + Notifikasi]
        end

        subgraph Layout["Main Layout"]
            direction LR

            subgraph Sidebar["Sidebar Navigasi"]
                direction TB
                Dash[Dashboard]
                Occ[Occupancy]
                Room[Kamar selected]
                Guest[Tamu]
                Bill[Billing]
                Logi[Logistik]
                Set[Settings]
            end

            subgraph Content["Content Area"]
                direction TB
                Title[Heading<br/>Manajemen Kamar]
                KPIRow[KPI Cards<br/>Total / Available / Occupied / Cleaning]

                subgraph Tabs["Tab Switcher"]
                    direction LR
                    TabRoom[Tab Rooms active]
                    TabHK[Tab Housekeeping]
                end

                subgraph Toolbar["Toolbar"]
                    direction LR
                    Filter[Filter Status / Tipe]
                    SortBy[Sort Dropdown]
                    AddBtn[+ Tambah Kamar]
                end

                subgraph Grid["Card Grid (3-col, equal heights)"]
                    direction LR
                    Card1[Room 101 Deluxe<br/>📷 Image 224px<br/>Status Available<br/>Edit / Delete]
                    Card2[Room 201 Suite<br/>📷 Image 224px<br/>Status Occupied<br/>Edit / Delete]
                    Card3[Room 305 Presidential<br/>📷 Image fallback chain<br/>Status Available<br/>Edit / Delete]
                end

                subgraph Dialog["Add / Edit Room Dialog"]
                    direction TB
                    DTitle[Form: Tambah / Edit Kamar]
                    FormFields[Fields:<br/>Nomor, Tipe, Lantai,<br/>Harga, Status]
                    ImgUpload[📤 Image Upload Area<br/>Drag-drop atau klik<br/>JPEG/PNG/WebP, max 5MB<br/>POST /api/rooms/upload-image]
                    ImgPreview[Preview thumbnail<br/>+ tombol Hapus]
                    BtnSave[Simpan Kamar]
                end

                Pagination[Pagination<br/>1 2 3 ...]
            end
        end

        TopBar --> Layout
    end

    classDef section fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef nav fill:#e0e7ff,stroke:#6366f1
    classDef cta fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    classDef row fill:#dcfce7,stroke:#10b981
    classDef upload fill:#fce7f3,stroke:#ec4899,stroke-width:2px

    class TopBar,Layout,Sidebar,Content,Tabs,Toolbar,Grid,Dialog section
    class Dash,Occ,Guest,Bill,Logi,Set,SBToggle,Breadcrumb,Search,UserMenu,TabHK,Filter,SortBy,Pagination,Title,KPIRow,DTitle,FormFields,BtnSave nav
    class AddBtn,TabRoom,Room cta
    class Card1,Card2,Card3 row
    class ImgUpload,ImgPreview upload
