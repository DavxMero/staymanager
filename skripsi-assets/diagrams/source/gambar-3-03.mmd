flowchart TD
    Start([User Akses StayManager]) --> Landing{Landing Page<br/>/page.tsx}
    Landing -->|Tamu| ChatbotPub[/chatbot - akses publik/]
    Landing -->|Klik Login| Login[/login - input email password/]

    ChatbotPub --> ChatBrowse{Mode Chatbot}
    ChatBrowse -->|Tanpa Login| InfoOnly[Cek info kamar fasilitas<br/>BOOKING DITOLAK]
    ChatBrowse -->|Login Guest| FullChat[Cek ketersediaan<br/>Buat reservasi<br/>Konfirmasi pembayaran]
    InfoOnly --> Login

    Login --> Auth{Supabase Auth<br/>signInWithPassword}
    Auth -->|Invalid| LoginErr[Toast error]
    LoginErr --> Login
    Auth -->|Valid| RoleCheck{Cek user_roles}

    RoleCheck -->|Hanya 'guest'| ChatbotAuth[/chatbot login mode/]
    RoleCheck -->|Staff role| Dashboard[/dashboard/]

    ChatbotAuth --> FullChat
    FullChat --> SaveRes[(reservations<br/>+ payments)]

    Dashboard --> Sidebar{Pilih Modul}
    Sidebar --> Occ[/occupancy<br/>Kalender + Check-in-out/]
    Sidebar --> Rooms[/rooms<br/>Tab Rooms + Tab Housekeeping/]
    Sidebar --> Guests[/guests<br/>CRUD tamu/]
    Sidebar --> Bill[/billing<br/>Invoice + Items/]
    Sidebar --> Fin[/financial<br/>Pendapatan/]
    Sidebar --> Exp[/expenses<br/>Pengeluaran/]
    Sidebar --> Logi[/logistics<br/>Inventaris + PO/]
    Sidebar --> GFac[/guest-facilities<br/>Layanan tamu/]
    Sidebar --> Rep[/reports<br/>Analitik + Export/]
    Sidebar --> Staff[/staff + /roles<br/>RBAC mgmt/]
    Sidebar --> Set[/settings<br/>Config hotel/]
    Sidebar --> Hist[/chat-history<br/>Riwayat chatbot/]

    Occ --> DBOps[(Supabase<br/>PostgreSQL)]
    Rooms --> DBOps
    Guests --> DBOps
    Bill --> DBOps
    Fin --> DBOps
    Exp --> DBOps
    Logi --> DBOps
    GFac --> DBOps
    Rep --> DBOps
    Staff --> DBOps
    Set --> DBOps
    Hist --> DBOps
    SaveRes --> DBOps

    DBOps --> RT{Realtime?}
    RT -->|occupancy + dashboard| RTSync[Live update via<br/>postgres_changes channel]
    RT -->|Lainnya| Manual[Refetch manual]

    Sidebar --> Logout([Logout → /login])

    classDef pubNode fill:#fef3c7,stroke:#f59e0b
    classDef authNode fill:#dbeafe,stroke:#3b82f6
    classDef dbNode fill:#dcfce7,stroke:#10b981
    class Landing,ChatbotPub,InfoOnly pubNode
    class Login,Auth,RoleCheck,ChatbotAuth,Dashboard,Sidebar authNode
    class DBOps,SaveRes,RT,RTSync dbNode
