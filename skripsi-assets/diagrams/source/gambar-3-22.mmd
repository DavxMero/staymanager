flowchart LR
    subgraph Page["Halaman Chatbot LLM"]
        direction TB
        subgraph TopBar["Top Bar"]
            direction LR
            Back[← Kembali]
            Title[Title: Asni AI Assistant]
            User[Avatar User / Login Status]
        end

        subgraph Body["Main Body Split Layout"]
            direction LR

            subgraph Left["Sidebar Riwayat (collapsible)"]
                direction TB
                NewBtn[+ New Chat]
                Hist1[Chat 22 Apr<br/>Cek kamar Deluxe]
                Hist2[Chat 18 Apr<br/>Booking 15-17]
                Hist3[Chat 10 Apr<br/>Tanya fasilitas]
            end

            subgraph Right["Chat Area"]
                direction TB
                Greet[Asni AI Greeting Bubble<br/>Halo, ada yang bisa<br/>dibantu?]
                Msg1[User Message Bubble<br/>Saya cari kamar 15-17 Juli]
                Bot1[Bot Reply Bubble<br/>+ DateSelector card]
                Bot2[Bot Reply Bubble<br/>+ ROOM_CARDS hybrid<br/>thumbnail + View Details<br/>→ Modal carousel + specs]
                LoginWall[Bot Reply Bubble<br/>+ LoginPromptCard<br/>shown if anonymous<br/>tries to book]
                Bot3[Bot Reply Bubble<br/>+ InteractiveBookingCard<br/>auto-fill name/email/phone<br/>from user_metadata]
                Bot4[Bot Reply Bubble<br/>+ PaymentOptions card]
            end
        end

        subgraph Footer["Footer Composer"]
            direction LR
            Input[Text Input<br/>Tulis pesan...]
            Attach[Attach Mic Button]
            Send[Send Button]
        end

        TopBar --> Body
        Body --> Footer
    end

    classDef section fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef bubble fill:#e0e7ff,stroke:#6366f1
    classDef bot fill:#fce7f3,stroke:#ec4899
    classDef user fill:#dcfce7,stroke:#10b981
    classDef cta fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    classDef wall fill:#fee2e2,stroke:#ef4444,stroke-width:2px

    class TopBar,Body,Left,Right,Footer section
    class NewBtn,Hist1,Hist2,Hist3,Input bubble
    class Greet,Bot1,Bot2,Bot3,Bot4 bot
    class Msg1 user
    class Send,Attach cta
    class LoginWall wall
