sequenceDiagram
    autonumber
    actor FD as Front Desk Staff
    participant UI as Occupancy Page<br/>(/occupancy/page.tsx)
    participant Dialog as CheckinDialog
    participant Action as Server Action<br/>(occupancy/actions.ts)
    participant SB as Supabase Client
    participant DB as PostgreSQL
    participant RT as Supabase Realtime

    FD->>UI: Buka /occupancy
    UI->>Action: adminFetchCalendarReservations()
    Action->>DB: SELECT reservations + rooms<br/>WHERE status NOT IN ('cancelled')
    DB-->>Action: reservations[]
    Action-->>UI: data
    UI-->>FD: Render kalender hunian

    FD->>UI: Klik kamar dengan reservasi<br/>status='confirmed'
    UI->>UI: setCheckinDialogOpen(true)
    UI->>Dialog: open dengan room data

    Dialog->>Action: adminFetchCheckinReservations(roomId)
    Action->>DB: SELECT reservations<br/>WHERE room_id = ?<br/>AND status = 'confirmed'<br/>AND check_in <= today
    DB-->>Action: eligible reservations
    Action-->>Dialog: list

    alt Walk-in (tanpa reservasi sebelumnya)
        FD->>Dialog: Toggle "Walk-In Guest"
        FD->>Dialog: Input nama, KTP, kontak
    else Pilih reservasi existing
        FD->>Dialog: Pilih reservation dari dropdown
    end

    FD->>Dialog: Klik "Lanjutkan ke Pembayaran"
    Dialog->>Dialog: handleCheckin() validate input<br/>setShowPayment(true)

    FD->>Dialog: Pilih payment method<br/>(Cash / Transfer / Card)
    FD->>Dialog: Klik "Process Payment"

    Dialog->>SB: INSERT INTO payments<br/>(reservation_id, amount,<br/>payment_method, transaction_id)
    SB->>DB: INSERT
    DB-->>SB: payment row

    Dialog->>SB: UPDATE reservations<br/>SET status='checked-in',<br/>actual_check_in=NOW()
    SB->>DB: UPDATE
    DB->>RT: emit postgres_changes event

    Dialog->>SB: UPDATE rooms<br/>SET status='occupied'
    SB->>DB: UPDATE
    DB->>RT: emit postgres_changes event

    Dialog->>SB: INSERT INTO invoices<br/>(reservation_id, invoice_number,<br/>total_amount, payment_method)
    SB->>DB: INSERT
    DB-->>SB: invoice row

    SB-->>Dialog: setInvoiceData(invoice)
    Dialog->>Dialog: setPaymentSuccess(true)
    Dialog-->>FD: Tampilkan success + Print Invoice button

    RT-->>UI: realtime sync<br/>(rooms + reservations updated)
    UI->>UI: Re-render kalender + KPI
    UI-->>FD: Status kamar berubah ke 'occupied'

    FD->>Dialog: Klik "Print Invoice"
    Dialog->>Dialog: window.print() trigger browser dialog
