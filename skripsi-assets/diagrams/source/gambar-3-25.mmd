flowchart TB
    subgraph Page["Halaman Modul Keuangan"]
        direction TB

        subgraph TopBar["Top Bar"]
            direction LR
            SBToggle[Sidebar Toggle]
            Breadcrumb[Breadcrumb<br/>Dashboard > Keuangan]
            Search[Global Search]
            UserMenu[Avatar Profile]
        end

        subgraph Layout["Main Layout"]
            direction LR

            subgraph Sidebar["Sidebar"]
                direction TB
                Dash[Dashboard]
                Fin[Financial selected]
                Bill[Billing]
                Exp[Expenses]
                Rep[Reports]
            end

            subgraph Content["Content Area"]
                direction TB
                Title[Heading<br/>Modul Keuangan]

                subgraph Filter["Filter Bar"]
                    direction LR
                    Period[Periode Hari Minggu Bulan Custom]
                    DateRange[Date Range Picker]
                    Export[Export Button]
                end

                subgraph KPI["KPI Cards Row"]
                    direction LR
                    Card1[Total Pendapatan MTD<br/>Rp 45.250.000<br/>+12 percent]
                    Card2[Total Pengeluaran<br/>Rp 12.300.000]
                    Card3[Laba Bersih<br/>Rp 32.950.000]
                    Card4[Transaksi Pending<br/>5 transaksi]
                end

                subgraph Charts["Charts Row"]
                    direction LR
                    Bar[Bar Chart<br/>Pendapatan per Hari<br/>30 hari terakhir]
                    Pie[Pie Chart<br/>Breakdown Sumber Income<br/>Booking Service POS]
                end

                subgraph Table["Tabel Transaksi"]
                    direction TB
                    Toolbar[Filter Sort Add Transaction]
                    Header[Kolom: Tanggal Tipe Deskripsi Jumlah Status Aksi]
                    Row1[15 Apr Income Booking 1023 Rp 1.5jt Paid]
                    Row2[14 Apr Expense Listrik Rp 800rb Paid]
                    Row3[14 Apr Income Booking 1022 Rp 750rb Pending]
                    PageNav[Pagination]
                end
            end
        end

        TopBar --> Layout
    end

    classDef section fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef nav fill:#e0e7ff,stroke:#6366f1
    classDef kpi fill:#dcfce7,stroke:#10b981,stroke-width:2px
    classDef chart fill:#fce7f3,stroke:#ec4899
    classDef cta fill:#fef3c7,stroke:#f59e0b,stroke-width:2px

    class TopBar,Layout,Sidebar,Content,Filter,KPI,Charts,Table section
    class Dash,Bill,Exp,Rep,SBToggle,Breadcrumb,Search,UserMenu,Period,DateRange,Toolbar,Header,Row1,Row2,Row3,PageNav,Title nav
    class Card1,Card2,Card3,Card4 kpi
    class Bar,Pie chart
    class Export,Fin cta
