sequenceDiagram
    autonumber
    actor User as Pengguna
    participant UI as Antarmuka
    participant Controller as Controller
    participant Service as Service
    participant DB as Database

    User->>UI: Input data login
    UI->>Controller: submit(email, password)
    Controller->>Service: validateCredentials(email, password)
    Service->>DB: SELECT user WHERE email = ?
    DB-->>Service: data user

    alt Data tidak ditemukan
        Service-->>Controller: error: user_not_found
        Controller-->>UI: response error
        UI-->>User: Tampilkan pesan error
    else User ditemukan
        Service->>Service: verifikasi password
        alt Password salah
            Service-->>Controller: error: invalid_password
            Controller-->>UI: response error
            UI-->>User: Tampilkan pesan error
        else Password benar
            Service->>Service: generate token JWT
            Service-->>Controller: { token, user }
            Controller-->>UI: response success
            UI-->>User: Redirect ke dashboard
        end
    end
