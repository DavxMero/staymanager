classDiagram
    direction LR

    class Pelanggan {
        -int id
        -string nama
        -string email
        +login()
        +daftar()
        +lihatProfil()
    }

    class Pesanan {
        -int id
        -date tanggal
        -decimal total
        -string status
        +buatPesanan()
        +batalkanPesanan()
        +hitungTotal()
    }

    class DetailPesanan {
        -int id
        -int kuantitas
        -decimal subtotal
        +tambahItem()
        +hapusItem()
    }

    class Produk {
        -int id
        -string nama
        -decimal harga
        -int stok
        +cekStok()
        +updateHarga()
    }

    class Kategori {
        -int id
        -string nama
        +tambahProduk()
    }

    Pelanggan "1" --> "*" Pesanan : membuat
    Pesanan "1" *-- "1..*" DetailPesanan : memiliki
    DetailPesanan "*" --> "1" Produk : merujuk
    Kategori "1" --> "*" Produk : mengelompokkan
