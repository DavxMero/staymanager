flowchart TD
    Start([Mulai]) --> Login[User Login]
    Login --> AuthCheck{Kredensial<br/>valid?}
    AuthCheck -->|Tidak| ShowError[Tampilkan pesan error]
    ShowError --> Login
    AuthCheck -->|Ya| Browse[Browse katalog produk]
    Browse --> Pick[Pilih produk]
    Pick --> AddCart[Tambah ke keranjang]
    AddCart --> More{Beli produk<br/>lain?}
    More -->|Ya| Browse
    More -->|Tidak| Checkout[Checkout]
    Checkout --> Payment[Proses Pembayaran]
    Payment --> PayResult{Pembayaran<br/>berhasil?}
    PayResult -->|Tidak| PayError[Tampilkan error<br/>pembayaran]
    PayError --> Payment
    PayResult -->|Ya| Confirm[Tampilkan konfirmasi]
    Confirm --> SendNotif[Kirim email notifikasi]
    SendNotif --> End([Selesai])

    classDef startEnd fill:#dcfce7,stroke:#10b981,stroke-width:2px
    classDef decision fill:#fef3c7,stroke:#f59e0b
    classDef action fill:#dbeafe,stroke:#3b82f6
    classDef error fill:#fee2e2,stroke:#ef4444

    class Start,End startEnd
    class AuthCheck,More,PayResult decision
    class Login,Browse,Pick,AddCart,Checkout,Payment,Confirm,SendNotif action
    class ShowError,PayError error
